{
  "name": "@folks-finance/folks-staking-sdk",
  "version": "0.0.3",
  "description": "The official JavaScript SDK for the $FOLKS Staking",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/Folks-Finance/folks-staking-js-sdk#readme",
  "bugs": {
    "url": "https://github.com/Folks-Finance/folks-staking-js-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Folks-Finance/folks-staking-js-sdk.git"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky",
    "commit": "cz",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write .",
    "formatcheck": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "viem": "^2.40.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@commitlint/cz-commitlint": "^20.1.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.48.0",
    "commitizen": "^4.3.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^0.5.3",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "viem": "^2.40.3"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "keywords": [
    "folks-finance",
    "folks",
    "staking",
    "blockchain",
    "evm"
  ],
  "packageManager": "pnpm@10.23.0"
}
